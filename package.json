{
  "name": "ruler",
  "version": "0.0.0",
  "private": true,
  "description": "Rule engine with visual editor and audit trace. GoRules JDM under the hood.",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "dev:web": "pnpm --filter demo-web dev",
    "dev:api": "uv run --package demo-api uvicorn demo_api.main:app --reload --port 8000",
    "lint": "pnpm -r lint"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
